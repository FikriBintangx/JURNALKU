generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// USER — Session-based (no auth required)
// ─────────────────────────────────────────────────────────────
model User {
  id           String          @id @default(cuid())
  name         String?
  email        String          @unique
  password     String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

// ─────────────────────────────────────────────────────────────
// JOURNAL — Cached paper metadata from external providers
// ─────────────────────────────────────────────────────────────
model Journal {
  id           String    @id
  title        String
  abstract     String?
  // Authors stored as JSON array: [{ name: "..." }, ...]
  authorsJson  String?   @map("authors_json")
  // Keep plain text author field for backward compatibility
  author       String?
  year         Int?
  source       String?
  sourceId     String?
  doi          String?   @unique
  venue        String?
  pdfUrl       String?
  externalUrl  String?
  isOpenAccess Boolean   @default(false)
  docType      String?
  citations    Int       @default(0)
  keywords     String[]  @default([])
  embedding    Float[]   @default([])
  createdAt    DateTime  @default(now())

  bookmarks    Bookmark[]
  summaries    Summary[]
  researchGaps ResearchGap[]
  interactions UserInteraction[]
}

// ─────────────────────────────────────────────────────────────
// BOOKMARK — Session-based (userId = session cookie value)
// ─────────────────────────────────────────────────────────────
model Bookmark {
  id        String   @id @default(cuid())
  userId    String   // session ID (cookie) — no FK to User for guest support
  journalId String
  createdAt DateTime @default(now())

  journal   Journal  @relation(fields: [journalId], references: [id], onDelete: Cascade)

  @@unique([userId, journalId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────
// SUMMARY — Cached AI summaries per paper
// ─────────────────────────────────────────────────────────────
model Summary {
  id        String   @id @default(cuid())
  journalId String
  content   String
  type      String   @default("basic")
  json      Json?
  journal   Journal  @relation(fields: [journalId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────
// RESEARCH GAP — Cached AI gap analysis per paper
// ─────────────────────────────────────────────────────────────
model ResearchGap {
  id        String   @id @default(cuid())
  journalId String   @unique
  content   String
  json      Json?
  journal   Journal  @relation(fields: [journalId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────
// USER INTERACTION — Analytics (click, view, share)
// Session-based: userId is a string ID (guest or registered)
// ─────────────────────────────────────────────────────────────
model UserInteraction {
  id        String   @id @default(cuid())
  userId    String
  journalId String
  type      String   // VIEW | CLICK | BOOKMARK | SHARE
  journal   Journal  @relation(fields: [journalId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────
// SEARCH HISTORY — Per session
// ─────────────────────────────────────────────────────────────
model History {
  id        String   @id @default(cuid())
  userId    String
  query     String
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────
// SEARCH CACHE — Redis-fallback cache in DB
// ─────────────────────────────────────────────────────────────
model SearchCache {
  id        String   @id @default(cuid())
  query     String   @unique
  results   Json
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// ISAGI LEVEL 5: PERSONAL WORKSPACE & VECTOR MEMORY
// ─────────────────────────────────────────────────────────────
model WorkspaceDocument {
  id        String   @id @default(cuid())
  userId    String   // Session ID or User ID for personal isolation
  title     String
  fileName  String
  content   String?  // Full extracted text
  type      String   // "pdf", "docx", "online"
  metadata  Json?    // Authors, year, publication, etc
  createdAt DateTime @default(now())

  chunks    DocumentChunk[]
  collections ResearchCollection[]
}

model DocumentChunk {
  id         String   @id @default(cuid())
  documentId String
  content    String   // The text chunk
  page       Int?
  section    String?  // e.g., "Methodology", "Conclusion"
  embedding  Float[]  // Semantic vector embedding
  document   WorkspaceDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────
// ISAGI LEVEL 5: COLLECTIONS & ORGANIZATION
// ─────────────────────────────────────────────────────────────
model ResearchCollection {
  id        String   @id @default(cuid())
  userId    String   // Session ID or User ID
  name      String
  color     String?  @default("yellow")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // A collection can have many workspace documents
  documents WorkspaceDocument[]
}

// ─────────────────────────────────────────────────────────────
// ISAGI LEVEL 5: DYNAMIC INTELLIGENCE & SESSIONS
// ─────────────────────────────────────────────────────────────
model AIConversation {
  id        String   @id @default(cuid())
  userId    String
  mode      String   @default("synthesis") // synthesis, review, compare
  title     String?  // auto-generated based on first query
  context   Json?    // Stores the memory context used
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages  AIMessage[]
}

model AIMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // "user", "assistant", "system"
  content        String
  agentState     Json?    // State of the swarm when answering (retriever, critic, graph, etc)
  createdAt      DateTime @default(now())

  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model ResearchGraph {
  id          String   @id @default(cuid())
  userId      String
  nodes       Json     // [{ id, label, type }]
  edges       Json     // [{ source, target, label }]
  documentIds String[] // Which documents generated this graph
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CompareSession {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  matrix    Json     // AI generated comparison matrix data
  papers    String[] // Array of document IDs being compared
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

